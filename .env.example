# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# Секретный ключ для JWT — ОБЯЗАТЕЛЬНО замени на случайную строку!
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=замени-на-длинную-случайную-строку-минимум-32-символа

# Redis URL (по умолчанию локальный)
REDIS_URL=redis://localhost:6379

# База данных SQLite
DATABASE_URL=sqlite+aiosqlite:///./users.db

# CORS — разрешённые домены через запятую
# Локальная разработка:
CORS_ORIGINS=http://localhost:8000
# Продакшн (пример):
# CORS_ORIGINS=https://твой-домен.ru,https://www.твой-домен.ru

# Хост и порт сервера
HOST=0.0.0.0
PORT=8000
